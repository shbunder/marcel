[Unit]
Description=Marcel personal assistant (Docker)
# Docker runs as a system service, not a user service — a user unit can't
# Require/After it. ExecStart will fail loudly if Docker isn't running, which
# is the correct behavior. (Regression from ISSUE-d2a2ce of the ISSUE-027 fix.)

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=@@REPO_ROOT@@
ExecStart=/usr/bin/docker compose up -d --build
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=300

[Install]
WantedBy=default.target
