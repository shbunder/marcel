# Marcel — watches for restart requests from the agent
# When Marcel modifies its own code it writes a flag file; this unit
# detects the file and triggers marcel-redeploy.service on the host.
[Unit]
Description=Watch for Marcel restart requests

[Path]
PathExists=@@DATA_DIR@@/watchdog/restart_requested
Unit=marcel-redeploy.service

[Install]
WantedBy=default.target
