ANTHROPIC_API_KEY=

MARCEL_HOST=localhost
MARCEL_PORT=7420

# Telegram channel integration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Optional: secret token to validate incoming webhook requests (recommended for production)
TELEGRAM_WEBHOOK_SECRET=

# Apple iCloud integration
# Generate an app-specific password at appleid.apple.com → Sign-In & Security → App-Specific Passwords
ICLOUD_APPLE_ID=
ICLOUD_APP_PASSWORD=
