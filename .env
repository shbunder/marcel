ANTHROPIC_API_KEY=

MARCEL_HOST=localhost
MARCEL_PORT=7420

# Default user slug (used when no user is specified by the client)
MARCEL_DEFAULT_USER=

# API token for WebSocket authentication (leave empty to allow unauthenticated access)
MARCEL_API_TOKEN=

# Passphrase for encrypting user credentials at rest (Fernet)
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, credentials are stored in plaintext (not recommended)
MARCEL_CREDENTIALS_KEY=

# Public HTTPS URL for this Marcel instance (e.g. https://marcel.example.com)
# Required for the Telegram Mini App "View in app" button. If unset, the
# button is simply not sent.
MARCEL_PUBLIC_URL=

# Telegram channel integration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Required: secret token to validate incoming webhook requests
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=
