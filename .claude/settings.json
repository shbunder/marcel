{
  "permissions": {
    "allow": [
      "Bash(.claude/scripts/issue-task status *)",
      "Bash(.claude/scripts/issue-task check *)",
      "Bash(.claude/scripts/issue-task log *)",
      "Edit(/.claude/skills/new-issue/**)",
      "Bash(.claude/scripts/issue-task --help)",
      "Bash(.claude/scripts/issue-task reopen *)"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git branch --list 'issue/*' | sed 's/^/  /' | head -5 || true; if [ -z \"$(git branch --list 'issue/*')\" ]; then echo 'No active issue branches'; fi",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard-restricted.py",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/issue-reminder.py",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  }
}